# ===================================
# TaskForce Tickets Environment Variables
# ===================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===================================
# Analytics & Tracking
# ===================================

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# CallRail
NEXT_PUBLIC_CALLRAIL_COMPANY_ID=your-company-id
CALLRAIL_API_KEY=your-callrail-api-key
CALLRAIL_ACCOUNT_ID=239100115

# Google Analytics 4 (Data API)
GOOGLE_ANALYTICS_PROPERTY_ID=properties/XXXXXXXXX
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google Search Console
SEARCH_CONSOLE_SITE_URL=https://taskforcetickets.com

# ===================================
# Webhooks & Integrations
# ===================================

# Lead Intake Webhook Security
WEBHOOK_SECRET=your-webhook-secret

# Zapier (optional)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/...

# 302 CRM (optional)
CRM_WEBHOOK_URL=https://your-crm-webhook

# ===================================
# Email (Resend)
# ===================================

RESEND_API_KEY=re_XXXXXXXXX

# ===================================
# Cron & Admin
# ===================================

# Weekly digest recipients (comma-separated)
WEEKLY_DIGEST_RECIPIENTS=will@302digitaladvisory.com

# Daily new-cases digest recipients (comma-separated)
# Consumed by /api/cron/new-cases-digest, called from .github/workflows/daily-new-cases.yml
NEW_CASES_DIGEST_RECIPIENTS=cshaw0305@gmail.com,info@taskforcetickets.com,developer@taskforcetickets.com

# Cron job authentication
CRON_SECRET=your-cron-secret

# Dashboard admin password (optional)
ADMIN_PASSWORD=your-admin-password

# ===================================
# Twilio (SMS)
# ===================================

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+19014458520

# ===================================
# Stripe (Payments)
# ===================================

STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ===================================
# Form Validation APIs
# ===================================

# Smarty (Address Validation & Autocomplete)
# Get credentials at: https://www.smarty.com/account/keys
SMARTY_AUTH_ID=your-smarty-auth-id
SMARTY_AUTH_TOKEN=your-smarty-auth-token

# Numverify (Phone Validation)
# Get API key at: https://numverify.com/dashboard
NUMVERIFY_API_KEY=your-numverify-api-key

# UserCheck (Email Validation)
# Free tier works without API key for basic validation
# Optional: USERCHECK_API_KEY for higher limits

# ===================================
# PandaDoc (Service Agreements)
# ===================================

# Get API key at: https://developers.pandadoc.com/reference/api-key-authentication
PANDADOC_API_KEY=your-pandadoc-api-key

# Template ID for service agreement (create in PandaDoc dashboard)
PANDADOC_TEMPLATE_ID=your-template-id

# Webhook secret for signature verification (optional but recommended)
PANDADOC_WEBHOOK_SECRET=your-webhook-secret
